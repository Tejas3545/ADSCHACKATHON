# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# MongoDB Atlas connection string
# Get it from: Atlas Dashboard → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/hackathon_leaderboard?retryWrites=true&w=majority&appName=Cluster0

# Database name (optional — defaults to hackathon_leaderboard)
MONGODB_DB=hackathon_leaderboard

# Password for the /admin panel
ADMIN_PASSWORD=change_me

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scope: public_repo  (add "repo" if using private repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Protects the /api/internal/poll cron endpoint from unauthorized access
# Use any random string. Set the SAME value in Vercel → Environment Variables.
CRON_SECRET=change_me_to_a_random_string

# GitHub Webhook Secret — only needed if you use webhooks instead of polling
# Leave empty to use polling only (recommended for hackathons)
GITHUB_WEBHOOK_SECRET=
